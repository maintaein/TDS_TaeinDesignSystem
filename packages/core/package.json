{
  "name": "@taein-designsystem/core",
  "version": "0.1.0",
  "description": "TDS_TaeinDesignSystem - React 기반 — 30개 컴포넌트, Zero-runtime CSS, Tree-shakable",
  "keywords": [
    "design-system",
    "react",
    "typescript",
    "vanilla-extract",
    "components",
    "ui",
    "accessible"
  ],
  "author": "Taein <daumdaum005@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maintaein/TDS_TaeinDesignSystem.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/maintaein/TDS_TaeinDesignSystem#readme",
  "bugs": {
    "url": "https://github.com/maintaein/TDS_TaeinDesignSystem/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/core.css"
  },
  "sideEffects": [
    "./dist/core.css"
  ],
  "files": [
    "dist",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.14.0",
    "clsx": "^2.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^4.0.5",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^23.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8"
  }
}
